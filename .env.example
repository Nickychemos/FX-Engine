# Compose publishes Postgres on 5435 locally (5432 is often already taken).
DATABASE_URL=postgresql+psycopg2://fx:fx@localhost:5435/fx
# ExchangeRate-API v6 base URL. The key is appended at request time.
RATES_API_URL=https://v6.exchangerate-api.com/v6
# Get a free key at exchangerate-api.com. Leave blank to run on the offline seed.
RATES_API_KEY=
SPREAD_BPS=50
RATE_MAX_STALENESS_SECONDS=300
QUOTE_TTL_SECONDS=60
